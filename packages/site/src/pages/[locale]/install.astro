---
import Base from '../../layouts/Base.astro'
import { t, localePath, type Locale } from '../../i18n'

export function getStaticPaths() {
  return [{ params: { locale: 'zh' } }, { params: { locale: 'en' } }]
}

const locale = Astro.params.locale as Locale
const i18n = t(locale)
const GITHUB_REPO = 'https://github.com/funAgent/ai-bubu'
---

<Base title={i18n.install.pageTitle} description={i18n.install.description}>
  <style>
    .install-nav {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(249, 249, 249, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .install-nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 680px;
      margin: 0 auto;
      padding: 12px 24px;
    }

    .install-back {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 14px;
      color: var(--text-2);
      transition: color 0.2s;
    }

    .install-back:hover {
      color: var(--text);
    }

    .lang-btn {
      font-size: 13px;
      font-weight: 600;
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--surface);
      color: var(--text-2);
      cursor: pointer;
      transition: all 0.2s;
    }

    .lang-btn:hover {
      color: var(--text);
      border-color: rgba(0, 0, 0, 0.15);
    }

    .install {
      max-width: 680px;
      margin: 0 auto;
      padding: 40px 24px 80px;
      line-height: 1.8;
      color: var(--text);
    }

    .install h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .install .subtitle {
      font-size: 14px;
      color: var(--text-2);
      margin-bottom: 40px;
      line-height: 1.6;
    }

    .install h2 {
      font-size: 18px;
      font-weight: 600;
      margin-top: 36px;
      margin-bottom: 12px;
    }

    .install p {
      font-size: 15px;
      color: var(--text-2);
      margin-bottom: 16px;
    }

    .install ol {
      padding-left: 20px;
      margin-bottom: 16px;
    }

    .install li {
      font-size: 15px;
      color: var(--text-2);
      margin-bottom: 8px;
    }

    .install code {
      font-family: 'SF Mono', 'Fira Code', 'Fira Mono', Menlo, monospace;
      font-size: 13px;
      background: rgba(0, 0, 0, 0.05);
      padding: 2px 6px;
      border-radius: 4px;
      color: var(--text);
      word-break: break-all;
    }

    .install pre {
      background: #1a1a1e;
      color: #e0e0e0;
      padding: 14px 18px;
      border-radius: 10px;
      overflow-x: auto;
      margin-bottom: 16px;
      font-family: 'SF Mono', 'Fira Code', 'Fira Mono', Menlo, monospace;
      font-size: 13px;
      line-height: 1.6;
    }

    .install pre code {
      background: none;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    .install .tip {
      background: rgba(99, 102, 241, 0.06);
      border-left: 3px solid var(--accent);
      padding: 12px 16px;
      border-radius: 0 8px 8px 0;
      margin-bottom: 16px;
      font-size: 14px;
      color: var(--text-2);
    }

    .method-tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.5px;
      color: var(--accent);
      background: rgba(99, 102, 241, 0.08);
      padding: 2px 8px;
      border-radius: 4px;
      margin-bottom: 8px;
      text-transform: uppercase;
    }

    .install a {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 2px;
      text-decoration-color: rgba(99, 102, 241, 0.3);
    }

    .install a:hover {
      text-decoration-color: var(--accent);
    }
  </style>

  <nav class="install-nav" aria-label="install">
    <div class="install-nav-inner">
      <a href={localePath(locale, '/')} class="install-back">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
        <span>{i18n.nav.backHome}</span>
      </a>
      <button class="lang-btn" id="langToggle" type="button" aria-label="Switch language">
        {i18n.nav.switchLang}
      </button>
    </div>
  </nav>

  <div class="install">
    {
      locale === 'zh' ? (
        <Fragment>
          <h1>macOS 安装指南</h1>
          <p class="subtitle">
            AI 步步是开源免费软件，尚未购买 Apple 开发者签名。首次打开时 macOS
            会弹出安全提示，按以下任一方法操作即可正常使用。
          </p>
          <h2>方法一：右键打开</h2>
          <div class="method-tag">推荐 · 最简单</div>
          <ol>
            <li>
              打开 <strong>Finder</strong>，进入「应用程序」文件夹
            </li>
            <li>
              找到 <strong>AIbubu</strong>，<strong>右键点击</strong>（或按住 Control 键点击）
            </li>
            <li>
              在菜单中选择「<strong>打开</strong>」
            </li>
            <li>
              弹窗中点击「<strong>打开</strong>」即可
            </li>
          </ol>
          <p class="tip">只需操作一次，之后可以正常双击打开。</p>
          <h2>方法二：终端命令</h2>
          <div class="method-tag">一行命令</div>
          <p>打开「终端」应用，粘贴以下命令并按回车：</p>
          <pre>
            <code>xattr -cr "/Applications/AIbubu.app"</code>
          </pre>
          <p>执行后即可正常双击打开应用。</p>
          <h2>方法三：系统设置放行</h2>
          <div class="method-tag">macOS Sequoia+</div>
          <ol>
            <li>双击打开应用，看到安全提示后关闭</li>
            <li>
              打开「<strong>系统设置</strong>」→「<strong>隐私与安全性</strong>」
            </li>
            <li>向下滚动到「安全性」部分，找到被阻止的应用</li>
            <li>
              点击「<strong>仍要打开</strong>」，输入密码确认
            </li>
          </ol>
          <h2>为什么会出现这个提示？</h2>
          <p>
            macOS 的 Gatekeeper 安全机制会检查应用是否经过 Apple 公证。AI
            步步是开源社区项目，暂未购买每年 $99 的 Apple 开发者账号进行公证签名，因此 macOS
            会弹出安全提示。应用本身是安全的，你可以随时在{' '}
            <a href={GITHUB_REPO} target="_blank" rel="noopener">
              GitHub
            </a>{' '}
            查看完整源代码。
          </p>
        </Fragment>
      ) : (
        <Fragment>
          <h1>macOS Install Guide</h1>
          <p class="subtitle">
            AIbubu is free and open-source software, not yet signed with an Apple Developer
            certificate. macOS will show a security warning on first launch — use any of the methods
            below to proceed.
          </p>
          <h2>Method 1: Right-click to Open</h2>
          <div class="method-tag">Recommended · Easiest</div>
          <ol>
            <li>
              Open <strong>Finder</strong> and go to the <strong>Applications</strong> folder
            </li>
            <li>
              Find <strong>AIbubu</strong>, then <strong>right-click</strong> (or Control-click) on
              it
            </li>
            <li>
              Select "<strong>Open</strong>" from the menu
            </li>
            <li>
              Click "<strong>Open</strong>" in the dialog
            </li>
          </ol>
          <p class="tip">
            You only need to do this once — after that, you can double-click to open normally.
          </p>
          <h2>Method 2: Terminal Command</h2>
          <div class="method-tag">One Command</div>
          <p>
            Open the <strong>Terminal</strong> app and paste the following command:
          </p>
          <pre>
            <code>xattr -cr "/Applications/AIbubu.app"</code>
          </pre>
          <p>After running, you can double-click the app to open it normally.</p>
          <h2>Method 3: System Settings</h2>
          <div class="method-tag">macOS Sequoia+</div>
          <ol>
            <li>Double-click the app and dismiss the security warning</li>
            <li>
              Open <strong>System Settings</strong> → <strong>Privacy & Security</strong>
            </li>
            <li>Scroll down to the "Security" section and find the blocked app</li>
            <li>
              Click "<strong>Open Anyway</strong>" and enter your password to confirm
            </li>
          </ol>
          <h2>Why does this warning appear?</h2>
          <p>
            macOS Gatekeeper checks whether apps are notarized by Apple. AIbubu is a community
            open-source project and does not yet have a $99/year Apple Developer account for
            notarization. The app is safe — you can review the full source code on{' '}
            <a href={GITHUB_REPO} target="_blank" rel="noopener">
              GitHub
            </a>{' '}
            at any time.
          </p>
        </Fragment>
      )
    }
  </div>

  <script>
    import { initLangToggle } from '../../scripts/lang-toggle'
    initLangToggle()
  </script>
</Base>
