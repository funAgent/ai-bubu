---
import Base from '../layouts/Base.astro'

const GITHUB_REPO = 'https://github.com/funAgent/ai-bubu'
const RELEASES_URL = `${GITHUB_REPO}/releases/latest`
---

<Base
  title="AI 步步 — AI 时代的编码计步器"
  description="实时监测 Cursor、Claude Code、Codex、Trae 等 AI 工具的使用量，化为桌面宠物的步数和动作。"
>
  <nav class="nav">
    <a href="/" class="logo">
      <span class="logo-label" data-i18n="brand">AI 步步</span>
    </a>
    <div class="nav-end">
      <button class="lang-btn" id="langToggle" type="button" aria-label="Switch language">
        EN
      </button>
      <a href={GITHUB_REPO} class="nav-link" target="_blank" rel="noopener">GitHub</a>
    </div>
  </nav>

  <main>
    <section class="hero">
      <div class="hero-demo">
        <video autoplay muted loop playsinline id="heroVideo" poster="/screenshot/demo.jpg">
          <source
            src="/demo/demo.mp4"
            type="video/mp4"
            data-src-zh="/demo/demo.mp4"
            data-src-en="/demo/demo_en.mp4"
          />
        </video>
      </div>

      <h1 data-i18n="title">AI 时代的<br />编码计步器</h1>

      <p class="hero-desc" data-i18n="desc">
        你的 AI 编码活动，化为桌面宠物的步数和动作——还能和同事一起跑
      </p>

      <div class="hero-actions">
        <a href={RELEASES_URL} class="btn-primary" id="downloadBtn">
          <span class="dl-icon" id="dlIcon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.32 2.32-2.14 4.45-3.74 4.25z"
              >
              </path>
            </svg>
          </span>
          <span data-i18n="dl" id="dlText">下载 macOS 版</span>
        </a>
        <a
          href={RELEASES_URL}
          class="btn-ghost btn-all-platforms"
          id="allPlatformsBtn"
          target="_blank"
          rel="noopener"
        >
          <span data-i18n="dlAll">所有平台</span>
        </a>
        <a href={GITHUB_REPO} class="btn-ghost" target="_blank" rel="noopener">GitHub</a>
      </div>

      <p class="hero-meta" id="heroMeta" data-i18n="meta">
        Beta · 支持 Cursor、Claude Code、Codex、Trae 等
      </p>
      <p class="hero-install-hint">
        <a href="/install" data-i18n="installHint">首次打开遇到安全提示？查看安装指南</a>
      </p>
    </section>

    <section class="states">
      <div class="state-card">
        <div class="state-visual">
          <img src="/pet/walk.gif" alt="Walk" width="64" height="64" />
        </div>
        <h3 data-i18n="s1t">它会走</h3>
        <p data-i18n="s1d">安安静静<br />陪你写代码</p>
      </div>
      <div class="state-card">
        <div class="state-visual">
          <img src="/pet/run.gif" alt="Run" width="64" height="64" />
        </div>
        <h3 data-i18n="s2t">它会跑</h3>
        <p data-i18n="s2d">用 AI 越多<br />跑得越快</p>
      </div>
      <div class="state-card">
        <div class="state-visual">
          <img src="/pet/sprint.gif" alt="Sprint" width="64" height="64" />
        </div>
        <h3 data-i18n="s3t">它飞奔</h3>
        <p data-i18n="s3d">全力编码<br />极速冲刺</p>
      </div>
      <div class="state-card">
        <div class="state-visual">
          <img src="/pet/together.gif" alt="Together" class="together-gif" />
        </div>
        <h3 data-i18n="s4t">一起跑</h3>
        <p data-i18n="s4d">局域网自动发现<br />和同事比拼步数</p>
      </div>
    </section>

    <section class="features">
      <h2 data-i18n="ftTitle">功能一览</h2>
      <div class="carousel" id="featCarousel">
        <div class="carousel-track">
          <div class="carousel-slide" data-index="0">
            <div class="slide-frame">
              <img
                src="/screenshot/today.jpg"
                alt="今日数据"
                loading="lazy"
                data-src-zh="/screenshot/today.jpg"
                data-src-en="/screenshot/today_en.jpg"
              />
            </div>
            <div class="slide-caption">
              <div class="slide-title" data-i18n="sl1">今日数据</div>
              <div class="slide-desc" data-i18n="sl1d">步数 · 活跃度 · 峰值，编码节奏尽在掌握</div>
            </div>
          </div>
          <div class="carousel-slide" data-index="1">
            <div class="slide-frame">
              <img
                src="/screenshot/rank.jpg"
                alt="同事排行"
                loading="lazy"
                data-src-zh="/screenshot/rank.jpg"
                data-src-en="/screenshot/rank_en.jpg"
              />
            </div>
            <div class="slide-caption">
              <div class="slide-title" data-i18n="sl2">同事排行</div>
              <div class="slide-desc" data-i18n="sl2d">局域网自动发现，看看谁今天跑得最远</div>
            </div>
          </div>
          <div class="carousel-slide" data-index="2">
            <div class="slide-frame">
              <img
                src="/screenshot/pet.jpg"
                alt="挑选角色"
                loading="lazy"
                data-src-zh="/screenshot/pet.jpg"
                data-src-en="/screenshot/pet_en.jpg"
              />
            </div>
            <div class="slide-caption">
              <div class="slide-title" data-i18n="sl3">挑选角色</div>
              <div class="slide-desc" data-i18n="sl3d">8 款像素伙伴，还能导入社区创作</div>
            </div>
          </div>
          <div class="carousel-slide" data-index="3">
            <div class="slide-frame">
              <img
                src="/screenshot/setting.jpg"
                alt="自由定制"
                loading="lazy"
                data-src-zh="/screenshot/setting.jpg"
                data-src-en="/screenshot/setting_en.jpg"
              />
            </div>
            <div class="slide-caption">
              <div class="slide-title" data-i18n="sl4">自由定制</div>
              <div class="slide-desc" data-i18n="sl4d">昵称 · 主题 · 自启动，一切由你做主</div>
            </div>
          </div>
        </div>
        <div class="carousel-dots">
          <button class="dot active" data-idx="0" type="button" aria-label="Slide 1"></button>
          <button class="dot" data-idx="1" type="button" aria-label="Slide 2"></button>
          <button class="dot" data-idx="2" type="button" aria-label="Slide 3"></button>
          <button class="dot" data-idx="3" type="button" aria-label="Slide 4"></button>
        </div>
      </div>
    </section>

    <section class="chars">
      <h2 data-i18n="chTitle">挑选你的伙伴</h2>
      <div class="chars-row">
        <div class="char-item">
          <div class="char-sprite char-doux"></div>
          <span class="char-name">Doux</span>
        </div>
        <div class="char-item">
          <div class="char-sprite char-vita"></div>
          <span class="char-name">Vita</span>
        </div>
        <div class="char-item">
          <div class="char-sprite char-mort"></div>
          <span class="char-name">Mort</span>
        </div>
        <div class="char-item">
          <div class="char-sprite char-tard"></div>
          <span class="char-name">Tard</span>
        </div>
      </div>
      <p class="chars-note" data-i18n="chNote">支持自定义角色 · 社区创作持续更新</p>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-row footer-links">
      <span class="footer-brand" data-i18n="brand">AI 步步</span>
      <span class="footer-dot">·</span>
      <a href={GITHUB_REPO} target="_blank" rel="noopener">GitHub</a>
      <span class="footer-dot">·</span>
      <a href="/install" data-i18n="fInstall">安装指南</a>
      <span class="footer-dot">·</span>
      <a href="/privacy" data-i18n="fPrivacy">隐私协议</a>
    </div>
    <div class="footer-row footer-credits">
      <span data-i18n="fCredit">像素角色来自</span>&nbsp;
      <a href="https://arks.itch.io/dino-characters" target="_blank" rel="noopener">arks</a>
      (<a href="https://x.com/ArksDigital" target="_blank" rel="noopener">@ArksDigital</a>)
    </div>

    <!-- 中文社交：二维码 -->
    <div class="footer-social footer-social-zh" id="socialZh">
      <div class="qr-group">
        <div class="qr-item">
          <img src="/me/wechat_mp.jpg" alt="公众号" width="64" height="64" loading="lazy" />
          <span>公众号</span>
        </div>
        <div class="qr-item">
          <img src="/me/xiaohongshu.jpg" alt="小红书" width="64" height="64" loading="lazy" />
          <span>小红书</span>
        </div>
        <div class="qr-item">
          <img src="/me/douyin.jpg" alt="抖音" width="64" height="64" loading="lazy" />
          <span>抖音</span>
        </div>
      </div>
    </div>

    <!-- 英文社交：X 链接 -->
    <div class="footer-social footer-social-en" id="socialEn" style="display:none">
      <div class="footer-row">
        <a href="https://x.com/funAgentApp" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            >
            </path>
          </svg>
          @funAgentApp
        </a>
        <span class="footer-dot">·</span>
        <a href="https://x.com/hash-panda" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            >
            </path>
          </svg>
          @hash-panda
        </a>
        <span class="footer-dot">·</span>
        <span data-i18n="fDev">Developer</span>
      </div>
    </div>

    <div class="footer-row">© 2026 aibubu.app</div>
  </footer>
</Base>

<script>
  import { initI18n } from '../scripts/i18n'

  const messages: Record<string, Record<string, string>> = {
    zh: {
      brand: 'AI 步步',
      title: 'AI 时代的<br/>编码计步器',
      desc: '你的 AI 编码活动，化为桌面宠物的步数和动作——还能和同事一起跑',
      dl: '下载 macOS 版',
      dlWin: '下载 Windows 版',
      dlLinux: '下载 Linux 版',
      dlAll: '所有平台',
      meta: 'Beta · 支持 Cursor、Claude Code、Codex、Trae 等',
      s1t: '它会走',
      s1d: '安安静静<br/>陪你写代码',
      s2t: '它会跑',
      s2d: '用 AI 越多<br/>跑得越快',
      s3t: '它飞奔',
      s3d: '全力编码<br/>极速冲刺',
      s4t: '一起跑',
      s4d: '局域网自动发现<br/>和同事比拼步数',
      ftTitle: '功能一览',
      sl1: '今日数据',
      sl1d: '步数 · 活跃度 · 峰值，编码节奏尽在掌握',
      sl2: '同事排行',
      sl2d: '局域网自动发现，看看谁今天跑得最远',
      sl3: '挑选角色',
      sl3d: '8 款像素伙伴，还能导入社区创作',
      sl4: '自由定制',
      sl4d: '昵称 · 主题 · 自启动，一切由你做主',
      chTitle: '挑选你的伙伴',
      chNote: '支持自定义角色 · 社区创作持续更新',
      fCredit: '像素角色来自',
      fInstall: '安装指南',
      fPrivacy: '隐私协议',
      installHint: '首次打开遇到安全提示？查看安装指南',
    },
    en: {
      brand: 'AIbubu',
      title: 'A step counter<br/>for the AI era',
      desc: "Your AI coding activity drives your pet's steps and moves — run with your team",
      dl: 'Download for macOS',
      dlWin: 'Download for Windows',
      dlLinux: 'Download for Linux',
      dlAll: 'All Platforms',
      meta: 'Beta · Supports Cursor, Claude Code, Codex, Trae &amp; more',
      s1t: 'It walks',
      s1d: 'Quietly keeping<br/>you company',
      s2t: 'It runs',
      s2d: 'More AI activity<br/>means more speed',
      s3t: 'It sprints',
      s3d: 'Full speed<br/>coding mode',
      s4t: 'Run together',
      s4d: 'Auto-discover on LAN<br/>compete with teammates',
      ftTitle: 'Features',
      sl1: 'Today',
      sl1d: 'Steps, activity, peak — your coding pulse at a glance',
      sl2: 'Leaderboard',
      sl2d: 'Auto-discover teammates, see who runs the farthest',
      sl3: 'Pick a buddy',
      sl3d: '8 pixel pals plus community imports',
      sl4: 'Make it yours',
      sl4d: 'Name, theme, auto-start — fully yours',
      chTitle: 'Pick your companion',
      chNote: 'Custom skins supported · More from the community',
      fCredit: 'Pixel art by',
      fInstall: 'Install Guide',
      fPrivacy: 'Privacy',
      installHint: 'Security warning on first launch? See install guide',
    },
  }

  const pageTitles: Record<string, string> = {
    zh: 'AI 步步 — AI 时代的编码计步器',
    en: 'AIbubu — A Step Counter for the AI Era',
  }

  const { getLang } = initI18n(messages, pageTitles)

  function applyLangAssets() {
    const l = getLang()
    const socialZh = document.getElementById('socialZh')
    const socialEn = document.getElementById('socialEn')
    if (socialZh) socialZh.style.display = l === 'zh' ? '' : 'none'
    if (socialEn) socialEn.style.display = l === 'en' ? '' : 'none'

    const srcKey = l === 'zh' ? 'data-src-zh' : 'data-src-en'
    document.querySelectorAll<HTMLImageElement>('img[data-src-zh]').forEach((img) => {
      img.src = img.getAttribute(srcKey) || img.src
    })
    const heroVideo = document.getElementById('heroVideo') as HTMLVideoElement | null
    if (heroVideo) {
      const source = heroVideo.querySelector('source[data-src-zh]')
      if (source) {
        source.setAttribute('src', source.getAttribute(srcKey) || '')
        heroVideo.load()
      }
    }
  }

  applyLangAssets()
  document.getElementById('langToggle')!.addEventListener('click', () => {
    setTimeout(() => {
      applyLangAssets()
      applyDownloadBtn()
    }, 0)
  })

  /* ━━ OS Detection & Download ━━━━━━━━━━━━━━━━━ */
  const GITHUB_API = 'https://api.github.com/repos/funAgent/ai-bubu/releases/latest'
  const RELEASES_FALLBACK = 'https://github.com/funAgent/ai-bubu/releases/latest'

  const SVG_MAC =
    '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.32 2.32-2.14 4.45-3.74 4.25z"/></svg>'
  const SVG_WIN =
    '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>'
