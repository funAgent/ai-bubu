---
import Base from '../layouts/Base.astro'

const GITHUB_REPO = 'https://github.com/funAgent/ai-bubu'
const DOWNLOAD_MAC = `${GITHUB_REPO}/releases/latest/download/AI.步步_0.1.0_aarch64.dmg`
---

<Base title="AI 步步 — AI 时代的编码计步器" description="实时监测 Cursor、Claude Code、Codex、Trae 等 AI 工具的使用量，化为桌面宠物的步数和动作。">

<nav class="nav">
  <a href="/" class="logo">
    <span class="logo-label" data-i18n="brand">AI 步步</span>
  </a>
  <div class="nav-end">
    <button class="lang-btn" id="langToggle" type="button" aria-label="Switch language">EN</button>
    <a href={GITHUB_REPO} class="nav-link" target="_blank" rel="noopener">GitHub</a>
  </div>
</nav>

<main>
  <section class="hero">
    <div class="hero-demo">
      <video autoplay muted loop playsinline id="heroVideo" poster="/screenshot/today.jpg">
        <source src="/demo/demo.mp4" type="video/mp4" data-src-zh="/demo/demo.mp4" data-src-en="/demo/demo_en.mp4" />
      </video>
    </div>

    <h1 data-i18n="title">AI 时代的<br/>编码计步器</h1>

    <p class="hero-desc" data-i18n="desc">
      你的 AI 编码活动，化为桌面宠物的步数和动作——还能和同事一起跑
    </p>

    <div class="hero-actions">
      <a href={DOWNLOAD_MAC} class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.32 2.32-2.14 4.45-3.74 4.25z"/></svg>
        <span data-i18n="dl">下载 macOS 版</span>
      </a>
      <a href={GITHUB_REPO} class="btn-ghost" target="_blank" rel="noopener">GitHub</a>
      <a href={`${GITHUB_REPO}/stargazers`} class="btn-ghost btn-star" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/></svg>
        <span>Star</span>
      </a>
    </div>

    <p class="hero-meta" data-i18n="meta">Beta v0.1 · 支持 Cursor、Claude Code、Codex、Trae 等</p>
    <p class="hero-install-hint">
      <a href="/install" data-i18n="installHint">首次打开遇到安全提示？查看安装指南</a>
    </p>
  </section>

  <section class="states">
    <div class="state-card">
      <div class="state-visual">
        <img src="/pet/walk.gif" alt="Walk" width="64" height="64" />
      </div>
      <h3 data-i18n="s1t">它会走</h3>
      <p data-i18n="s1d">安安静静<br/>陪你写代码</p>
    </div>
    <div class="state-card">
      <div class="state-visual">
        <img src="/pet/run.gif" alt="Run" width="64" height="64" />
      </div>
      <h3 data-i18n="s2t">它会跑</h3>
      <p data-i18n="s2d">用 AI 越多<br/>跑得越快</p>
    </div>
    <div class="state-card">
      <div class="state-visual">
        <img src="/pet/sprint.gif" alt="Sprint" width="64" height="64" />
      </div>
      <h3 data-i18n="s3t">它飞奔</h3>
      <p data-i18n="s3d">全力编码<br/>极速冲刺</p>
    </div>
    <div class="state-card">
      <div class="state-visual">
        <img src="/pet/together.gif" alt="Together" class="together-gif" />
      </div>
      <h3 data-i18n="s4t">一起跑</h3>
      <p data-i18n="s4d">局域网自动发现<br/>和同事比拼步数</p>
    </div>
  </section>

  <section class="features">
    <h2 data-i18n="ftTitle">功能一览</h2>
    <div class="carousel" id="featCarousel">
      <div class="carousel-track">
        <div class="carousel-slide" data-index="0">
          <div class="slide-frame">
            <img src="/screenshot/today.jpg" alt="今日数据" loading="lazy" data-src-zh="/screenshot/today.jpg" data-src-en="/screenshot/today_en.jpg" />
          </div>
          <div class="slide-caption">
            <div class="slide-title" data-i18n="sl1">今日数据</div>
            <div class="slide-desc" data-i18n="sl1d">步数 · 活跃度 · 峰值，编码节奏尽在掌握</div>
          </div>
        </div>
        <div class="carousel-slide" data-index="1">
          <div class="slide-frame">
            <img src="/screenshot/rank.jpg" alt="同事排行" loading="lazy" data-src-zh="/screenshot/rank.jpg" data-src-en="/screenshot/rank_en.jpg" />
          </div>
          <div class="slide-caption">
            <div class="slide-title" data-i18n="sl2">同事排行</div>
            <div class="slide-desc" data-i18n="sl2d">局域网自动发现，看看谁今天跑得最远</div>
          </div>
        </div>
        <div class="carousel-slide" data-index="2">
          <div class="slide-frame">
            <img src="/screenshot/pet.jpg" alt="挑选角色" loading="lazy" data-src-zh="/screenshot/pet.jpg" data-src-en="/screenshot/pet_en.jpg" />
          </div>
          <div class="slide-caption">
            <div class="slide-title" data-i18n="sl3">挑选角色</div>
            <div class="slide-desc" data-i18n="sl3d">8 款像素伙伴，还能导入社区创作</div>
          </div>
        </div>
        <div class="carousel-slide" data-index="3">
          <div class="slide-frame">
            <img src="/screenshot/setting.jpg" alt="自由定制" loading="lazy" data-src-zh="/screenshot/setting.jpg" data-src-en="/screenshot/setting_en.jpg" />
          </div>
          <div class="slide-caption">
            <div class="slide-title" data-i18n="sl4">自由定制</div>
            <div class="slide-desc" data-i18n="sl4d">昵称 · 主题 · 自启动，一切由你做主</div>
          </div>
        </div>
      </div>
      <div class="carousel-dots">
        <button class="dot active" data-idx="0" type="button" aria-label="Slide 1"></button>
        <button class="dot" data-idx="1" type="button" aria-label="Slide 2"></button>
        <button class="dot" data-idx="2" type="button" aria-label="Slide 3"></button>
        <button class="dot" data-idx="3" type="button" aria-label="Slide 4"></button>
      </div>
    </div>
  </section>

  <section class="chars">
    <h2 data-i18n="chTitle">挑选你的伙伴</h2>
    <div class="chars-row">
      <div class="char-item">
        <div class="char-sprite char-doux"></div>
        <span class="char-name">Doux</span>
      </div>
      <div class="char-item">
        <div class="char-sprite char-vita"></div>
        <span class="char-name">Vita</span>
      </div>
      <div class="char-item">
        <div class="char-sprite char-mort"></div>
        <span class="char-name">Mort</span>
      </div>
      <div class="char-item">
        <div class="char-sprite char-tard"></div>
        <span class="char-name">Tard</span>
      </div>
    </div>
    <p class="chars-note" data-i18n="chNote">支持自定义角色 · 社区创作持续更新</p>
  </section>
</main>

<footer class="footer">
  <div class="footer-row footer-links">
    <span class="footer-brand" data-i18n="brand">AI 步步</span>
    <span class="footer-dot">·</span>
    <a href={GITHUB_REPO} target="_blank" rel="noopener">GitHub</a>
    <span class="footer-dot">·</span>
    <a href="/install" data-i18n="fInstall">安装指南</a>
    <span class="footer-dot">·</span>
    <a href="/privacy" data-i18n="fPrivacy">隐私协议</a>
  </div>
  <div class="footer-row footer-credits">
    <span data-i18n="fCredit">像素角色来自</span>&nbsp;
    <a href="https://arks.itch.io/dino-characters" target="_blank" rel="noopener">arks</a>
    (<a href="https://x.com/ArksDigital" target="_blank" rel="noopener">@ArksDigital</a>)
  </div>

  <!-- 中文社交：二维码 -->
  <div class="footer-social footer-social-zh" id="socialZh">
    <div class="qr-group">
      <div class="qr-item">
        <img src="/me/wechat_mp.jpg" alt="公众号" width="64" height="64" loading="lazy" />
        <span>公众号</span>
      </div>
      <div class="qr-item">
        <img src="/me/xiaohongshu.jpg" alt="小红书" width="64" height="64" loading="lazy" />
        <span>小红书</span>
      </div>
      <div class="qr-item">
        <img src="/me/douyin.jpg" alt="抖音" width="64" height="64" loading="lazy" />
        <span>抖音</span>
      </div>
    </div>
  </div>

  <!-- 英文社交：X 链接 -->
  <div class="footer-social footer-social-en" id="socialEn" style="display:none">
    <div class="footer-row">
      <a href="https://x.com/funAgentApp" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        @funAgentApp
      </a>
      <span class="footer-dot">·</span>
      <a href="https://x.com/hash-panda" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        @hash-panda
      </a>
      <span class="footer-dot">·</span>
      <span data-i18n="fDev">Developer</span>
    </div>
  </div>

  <div class="footer-row">© 2026 funAgent.app</div>
</footer>

</Base>

<script>
  import { initI18n } from '../scripts/i18n'

  const messages: Record<string, Record<string, string>> = {
    zh: {
      brand: 'AI 步步',
      title: 'AI 时代的<br/>编码计步器',
      desc: '你的 AI 编码活动，化为桌面宠物的步数和动作——还能和同事一起跑',
      dl: '下载 macOS 版',
      meta: 'Beta v0.1 · 支持 Cursor、Claude Code、Codex、Trae 等',
      s1t: '它会走', s1d: '安安静静<br/>陪你写代码',
      s2t: '它会跑', s2d: '用 AI 越多<br/>跑得越快',
      s3t: '它飞奔', s3d: '全力编码<br/>极速冲刺',
      s4t: '一起跑', s4d: '局域网自动发现<br/>和同事比拼步数',
      ftTitle: '功能一览',
      sl1: '今日数据', sl1d: '步数 · 活跃度 · 峰值，编码节奏尽在掌握',
      sl2: '同事排行', sl2d: '局域网自动发现，看看谁今天跑得最远',
      sl3: '挑选角色', sl3d: '8 款像素伙伴，还能导入社区创作',
      sl4: '自由定制', sl4d: '昵称 · 主题 · 自启动，一切由你做主',
      chTitle: '挑选你的伙伴',
      chNote: '支持自定义角色 · 社区创作持续更新',
      fCredit: '像素角色来自',
      fInstall: '安装指南',
      fPrivacy: '隐私协议',
      installHint: '首次打开遇到安全提示？查看安装指南',
    },
    en: {
      brand: 'AIbubu',
      title: 'A step counter<br/>for the AI era',
      desc: 'Your AI coding activity drives your pet\'s steps and moves — run with your team',
      dl: 'Download for macOS',
      meta: 'Beta v0.1 · Supports Cursor, Claude Code, Codex, Trae &amp; more',
      s1t: 'It walks', s1d: 'Quietly keeping<br/>you company',
      s2t: 'It runs', s2d: 'More AI activity<br/>means more speed',
      s3t: 'It sprints', s3d: 'Full speed<br/>coding mode',
      s4t: 'Run together', s4d: 'Auto-discover on LAN<br/>compete with teammates',
      ftTitle: 'Features',
      sl1: 'Today', sl1d: 'Steps, activity, peak — your coding pulse at a glance',
      sl2: 'Leaderboard', sl2d: 'Auto-discover teammates, see who runs the farthest',
      sl3: 'Pick a buddy', sl3d: '8 pixel pals plus community imports',
      sl4: 'Make it yours', sl4d: 'Name, theme, auto-start — fully yours',
      chTitle: 'Pick your companion',
      chNote: 'Custom skins supported · More from the community',
      fCredit: 'Pixel art by',
      fInstall: 'Install Guide',
      fPrivacy: 'Privacy',
      installHint: 'Security warning on first launch? See install guide',
    },
  }

  const pageTitles: Record<string, string> = {
    zh: 'AI 步步 — AI 时代的编码计步器',
    en: 'AIbubu — A Step Counter for the AI Era',
  }

  const { getLang } = initI18n(messages, pageTitles)

  function applyLangAssets() {
    const l = getLang()
    const socialZh = document.getElementById('socialZh')
    const socialEn = document.getElementById('socialEn')
    if (socialZh) socialZh.style.display = l === 'zh' ? '' : 'none'
    if (socialEn) socialEn.style.display = l === 'en' ? '' : 'none'

    const srcKey = l === 'zh' ? 'data-src-zh' : 'data-src-en'
    document.querySelectorAll<HTMLImageElement>('img[data-src-zh]').forEach((img) => {
      img.src = img.getAttribute(srcKey) || img.src
    })
    const heroVideo = document.getElementById('heroVideo') as HTMLVideoElement | null
    if (heroVideo) {
      const source = heroVideo.querySelector('source[data-src-zh]')
      if (source) {
        source.setAttribute('src', source.getAttribute(srcKey) || '')
        heroVideo.load()
      }
    }
  }

  applyLangAssets()
  document.getElementById('langToggle')!.addEventListener('click', () => {
    setTimeout(applyLangAssets, 0)
  })

  /* ━━ Carousel ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  ;(function initCarousel() {
    const carousel = document.getElementById('featCarousel')
    if (!carousel) return

    const slides = carousel.querySelectorAll<HTMLElement>('.carousel-slide')
    const dots = carousel.querySelectorAll<HTMLElement>('.dot')
    const total = slides.length
    let current = 0
    let timer: ReturnType<typeof setInterval>

    function posFor(slideIdx: number, activeIdx: number): string {
      const diff = (slideIdx - activeIdx + total) % total
      if (diff === 0) return 'active'
      if (diff === 1) return 'next'
      if (diff === total - 1) return 'prev'
      if (diff === 2) return 'far-next'
      return 'far-prev'
    }

    function goTo(idx: number) {
      current = ((idx % total) + total) % total
      slides.forEach((s, i) => s.setAttribute('data-pos', posFor(i, current)))
      dots.forEach((d, i) => d.classList.toggle('active', i === current))
    }

    function advance() { goTo(current + 1) }

    function startAuto() { timer = setInterval(advance, 4000) }
    function stopAuto() { clearInterval(timer) }

    carousel.addEventListener('mouseenter', stopAuto)
    carousel.addEventListener('mouseleave', startAuto)

    dots.forEach(d => {
      d.addEventListener('click', () => {
        const idx = parseInt(d.getAttribute('data-idx') || '0', 10)
        stopAuto()
        goTo(idx)
        startAuto()
      })
    })

    slides.forEach(s => {
      s.addEventListener('click', () => {
        const pos = s.getAttribute('data-pos')
        if (pos === 'prev') { stopAuto(); goTo(current - 1); startAuto() }
        if (pos === 'next') { stopAuto(); goTo(current + 1); startAuto() }
      })
    })

    goTo(0)
    startAuto()
  })()
</script>

<style>
  /* ━━ Nav ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .nav {
    max-width: 860px;
    margin: 0 auto;
    padding: 24px 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-mark {
    width: 26px;
    height: 26px;
    display: grid;
    place-items: center;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 7px;
    font-size: 12px;
    font-weight: 700;
    color: var(--text-2);
    font-family: 'Space Grotesk', sans-serif;
  }

  .logo-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.3px;
  }

  .nav-end {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .lang-btn {
    background: none;
    border: 1px solid rgba(0, 0, 0, 0.1);
    color: var(--text-3);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
  }

  .lang-btn:hover {
    border-color: rgba(0, 0, 0, 0.2);
    color: var(--text-2);
  }

  .nav-link {
    font-size: 13px;
    color: var(--text-3);
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--text);
  }

  /* ━━ Hero ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .hero {
    max-width: 860px;
    margin: 0 auto;
    padding: 24px 24px 24px;
    text-align: center;
  }

  .hero-demo {
    position: relative;
    display: inline-block;
    margin-bottom: 32px;
    animation: fadeDown 0.6s ease-out;
  }

  .hero-demo video {
    width: min(466px, 90vw);
    height: auto;
    image-rendering: pixelated;
    border-radius: 12px;
  }

  h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(32px, 6vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -2px;
    animation: fadeUp 0.6s ease-out;
  }

  .hero-desc {
    margin-top: 24px;
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-2);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    animation: fadeUp 0.6s ease-out 0.06s both;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 40px;
    animation: fadeUp 0.6s ease-out 0.12s both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--text);
    color: var(--bg);
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s ease-out;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-2);
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s ease-out;
  }

  .btn-ghost:hover {
    border-color: rgba(0, 0, 0, 0.2);
    color: var(--text);
  }

  .btn-star svg {
    transition: all 0.2s ease-out;
  }

  .btn-star:hover svg {
    fill: #fbbf24;
    transform: scale(1.1);
  }

  .hero-meta {
    margin-top: 16px;
    font-size: 12px;
    color: var(--text-3);
    letter-spacing: 0.2px;
    animation: fadeUp 0.6s ease-out 0.18s both;
  }

  .hero-install-hint {
    margin-top: 10px;
    font-size: 12px;
    animation: fadeUp 0.6s ease-out 0.22s both;
  }

  .hero-install-hint a {
    color: var(--text-3);
    text-decoration: underline;
    text-decoration-color: rgba(0, 0, 0, 0.15);
    text-underline-offset: 2px;
    transition: all 0.2s;
  }

  .hero-install-hint a:hover {
    color: var(--text-2);
    text-decoration-color: rgba(0, 0, 0, 0.4);
  }

  /* ━━ States ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .states {
    max-width: 860px;
    margin: 0 auto;
    padding: 16px 24px 64px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    animation: fadeUp 0.6s ease-out 0.24s both;
  }

  .state-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px 14px 20px;
    text-align: center;
    transition: all 0.25s ease-out;
