  type OSType = 'mac' | 'win' | 'linux'

  function detectOS(): OSType {
    const ua = navigator.userAgent.toLowerCase()
    if (ua.includes('win')) return 'win'
    if (ua.includes('linux') && !ua.includes('android')) return 'linux'
    return 'mac'
  }

  const dlTextMap: Record<string, Record<OSType, string>> = {
    zh: { mac: '下载 macOS 版', win: '下载 Windows 版', linux: '下载 Linux 版' },
    en: { mac: 'Download for macOS', win: 'Download for Windows', linux: 'Download for Linux' },
  }
  const dlIconMap: Record<OSType, string> = { mac: SVG_MAC, win: SVG_WIN, linux: SVG_LINUX }

  function applyDownloadBtn() {
    const os = detectOS()
    const lang = getLang()
    const dlText = document.getElementById('dlText')
    const dlIcon = document.getElementById('dlIcon')
    if (dlText) dlText.textContent = dlTextMap[lang]?.[os] || dlTextMap.en[os]
    if (dlIcon) dlIcon.innerHTML = dlIconMap[os]
  }

  applyDownloadBtn()

  function matchAsset(
    assets: Array<{ name: string; browser_download_url: string }>,
    os: OSType,
  ): string | null {
    for (const a of assets) {
      const n = a.name.toLowerCase()
      if (os === 'mac' && n.endsWith('.dmg') && n.includes('aarch64')) return a.browser_download_url
      if (os === 'win' && n.endsWith('.msi')) return a.browser_download_url
      if (os === 'linux' && n.endsWith('.appimage')) return a.browser_download_url
    }
    return null
  }

  fetch(GITHUB_API)
    .then((r) => r.json())
    .then(
      (data: {
        tag_name?: string
        assets?: Array<{ name: string; browser_download_url: string }>
      }) => {
        const tag = data.tag_name
        if (tag) {
          const ver = tag.replace(/^v/, '')
          const metaEl = document.getElementById('heroMeta')
          if (metaEl) {
            const lang = getLang()
            const suffix =
              lang === 'zh'
                ? ` · 支持 Cursor、Claude Code、Codex、Trae 等`
                : ` · Supports Cursor, Claude Code, Codex, Trae & more`
            metaEl.textContent = `v${ver}${suffix}`
          }
        }

        if (data.assets) {
          const os = detectOS()
          const url = matchAsset(data.assets, os)
          const btn = document.getElementById('downloadBtn') as HTMLAnchorElement | null
          if (btn && url) btn.href = url
        }
      },
    )
    .catch(() => {
      const btn = document.getElementById('downloadBtn') as HTMLAnchorElement | null
      if (btn) btn.href = RELEASES_FALLBACK
    })

  /* ━━ Carousel ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  ;(function initCarousel() {
    const carousel = document.getElementById('featCarousel')
    if (!carousel) return

    const slides = carousel.querySelectorAll<HTMLElement>('.carousel-slide')
    const dots = carousel.querySelectorAll<HTMLElement>('.dot')
    const total = slides.length
    let current = 0
    let timer: ReturnType<typeof setInterval>

    function posFor(slideIdx: number, activeIdx: number): string {
      const diff = (slideIdx - activeIdx + total) % total
      if (diff === 0) return 'active'
      if (diff === 1) return 'next'
      if (diff === total - 1) return 'prev'
      if (diff === 2) return 'far-next'
      return 'far-prev'
    }

    function goTo(idx: number) {
      current = ((idx % total) + total) % total
      slides.forEach((s, i) => s.setAttribute('data-pos', posFor(i, current)))
      dots.forEach((d, i) => d.classList.toggle('active', i === current))
    }

    function advance() {
      goTo(current + 1)
    }

    function startAuto() {
      timer = setInterval(advance, 4000)
    }
    function stopAuto() {
      clearInterval(timer)
    }

    carousel.addEventListener('mouseenter', stopAuto)
    carousel.addEventListener('mouseleave', startAuto)

    dots.forEach((d) => {
      d.addEventListener('click', () => {
        const idx = parseInt(d.getAttribute('data-idx') || '0', 10)
        stopAuto()
        goTo(idx)
        startAuto()
      })
    })

    slides.forEach((s) => {
      s.addEventListener('click', () => {
        const pos = s.getAttribute('data-pos')
        if (pos === 'prev') {
          stopAuto()
          goTo(current - 1)
          startAuto()
        }
        if (pos === 'next') {
          stopAuto()
          goTo(current + 1)
          startAuto()
        }
      })
    })

    goTo(0)
    startAuto()
  })()
</script>

